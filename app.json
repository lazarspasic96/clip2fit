{
  "expo": {
    "name": "clip2fit",
    "slug": "clip2fit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "clip2fit",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#09090b",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lazarspasic96.clip2fit",
      "infoPlist": {
        "NSCameraUsageDescription": "Clip2Fit uses your camera to analyze your exercise form in real-time and provide personalized coaching feedback.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.lazarspasic96.clip2fit"
        ]
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.lazarspasic96.clip2fit",
      "permissions": [
        "CAMERA"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#09090b"
        }
      ],
      "expo-sqlite",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.911676643313-rq7ho5qv199r5ls7msvb7dma35idg300"
        }
      ],
      [
        "expo-sharing",
        {
          "ios": {
            "enabled": true,
            "extensionBundleIdentifier": "com.lazarspasic96.clip2fit.share-extension",
            "appGroupId": "group.com.lazarspasic96.clip2fit",
            "activationRule": {
              "supportsText": true,
              "supportsWebUrlWithMaxCount": 1,
              "supportsWebPageWithMaxCount": 1
            }
          },
          "android": {
            "enabled": true,
            "singleShareMimeTypes": [
              "text/plain"
            ]
          }
        }
      ],
      "expo-image",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "063aaaa6-1910-4882-96ab-a62c0ec5f5af"
      }
    },
    "owner": "lazarspasic96s-organization"
  }
}
